includes:
    - ./vendor/nunomaduro/larastan/extension.neon

parameters:
    paths:
        - app/
        - config/
        - database/
        - routes/

    # Level 9 is the highest level
    level: 5

    ignoreErrors:
        # Ignore some standard Laravel patterns if needed
        # - '#PHPDoc tag @var# '

    excludePaths:
        # - ./*/*/FileToBeExcluded.php

    checkMissingIterableValueType: false
